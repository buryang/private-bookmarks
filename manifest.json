{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.2",
  "description": "__MSG_extensionDesc__",
  "default_locale": "en",
  "permissions": [
    "storage",
    "bookmarks",
    "contextMenus",
    "tabs",
    "notifications"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "open-private-bookmarks": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Open private bookmarks"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
